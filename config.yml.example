server:
  port: "8080"
  storage_path: "deploys.jsonl"  # путь к JSONL-файлу с историей деплоев
  history_size: 3                 # сколько последних деплоев хранить на проект

deploy_header_key: "X-Gitlab-Token"

# Конфигурация проектов: ключ = секрет из GitLab webhook
projects:
  "backend-secret-token-xyz":
    name: "Backend API"
    working_dir: "/var/www/backend-api"
    ssh_key_path: "/home/deploy/.ssh/id_rsa_gitlab"
    deploy_branch: "master"
    debounce_time: "30s"
    deploy_steps:
      - cmd: "docker"
        args: ["compose", "pull"]
      - cmd: "docker"
        args: ["compose", "up", "-d", "--remove-orphans"]

  "frontend-secret-token-abc":
    name: "Frontend"
    working_dir: "/var/www/frontend"
    ssh_key_path: "/home/deploy/.ssh/id_rsa_gitlab"
    deploy_branch: "main"
    debounce_time: "15s"
    deploy_steps:
      - cmd: "npm"
        args: ["install"]
      - cmd: "npm"
        args: ["run", "build"]
      - cmd: "systemctl"
        args: ["restart", "nginx"]

# --- Уведомления ---

telegram:
  enabled: true
  bot_token: "YOUR_BOT_TOKEN"
  chat_id: 123456789
  thread_id: 0  # 0 = без топика

ntfy:
  enabled: false
  url: "https://ntfy.sh/my-topic"  # или self-hosted: http://ntfy.example.com/topic
  token: ""                         # Bearer-токен, если включена авторизация
  priority: 0                       # 0 = auto (3 для info, 4 для warning, 5 для error)

# notify управляет, куда и как отправлять события деплоя.
# mode: "all"      — отправить во все каналы
# mode: "fallback" — попробовать по очереди, остановиться на первом доступном
# channels: порядок важен для fallback
notify:
  mode: "fallback"
  channels:
    - telegram
    - ntfy

# --- Статус деплоев ---
# GET /status             → все проекты (indented JSON)
# GET /status?name=NAME   → один проект по имени
# Рекомендуется закрыть через nginx auth_basic или разрешить только с localhost.
